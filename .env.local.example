# Copy this file to .env.local and fill in your own keys (never commit .env.local).
#
# Google AI Studio key (aistudio.google.com) — requires a paid-tier project.
# Covers Omni Flash video generation, Look Anchor image relight, scene
# inventory, and the Gemini judge:
GEMINI_API_KEY=

# Anthropic key (console.anthropic.com) — the Claude judge. Optional: without
# it the app still runs, but the disagreement-based confidence meter loses
# its second opinion:
ANTHROPIC_API_KEY=

# Deployed persistence (both are required together; hosted production fails
# closed rather than falling back to an ephemeral filesystem). The Blob store
# itself must be created as PRIVATE; this explicit value is an operator
# attestation and does not convert an existing public store:
BLOB_READ_WRITE_TOKEN=
DATABASE_URL=
FLORA_BLOB_ACCESS=private

# Required when hosted: 20+ characters with no leading/trailing whitespace.
# Prefer a randomly generated 32+ character value. Optional only in local dev:
FLORA_ACCESS_PASSWORD=

# Detailed ffmpeg diagnostics. Keep disabled; enable only briefly while
# investigating a deployment and disable/redeploy immediately afterwards:
FLORA_FFMPEG_DEBUG_ENABLED=0

# Provider-free Vercel Workflow control-plane probe. Keep disabled normally.
# Temporarily set to 1, redeploy, run /api/debug/workflow as documented in the
# README, then set back to 0 and redeploy. This never authorizes provider calls.
FLORA_WORKFLOW_SMOKE_ENABLED=0

# Optional local-only override for the data directory:
# FLORA_DATA_DIR=/absolute/path/to/flora-data
